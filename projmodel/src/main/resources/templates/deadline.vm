<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>$pageTitle</title>
    <link rel="stylesheet" type="text/css" href="$req.contextPath/download/resources/com.projmodel.projmodel:projmodel-resources/projmodel.css">
</head>
<body>
<div class="projmodel-container">
    <div class="projmodel-header">
        <a href="$req.contextPath/plugins/servlet/projmodel" class="projmodel-back-link">← На главную</a>
        <h1>$pageTitle</h1>
        <p class="projmodel-subtitle">$pageDescription</p>
        <p class="projmodel-version">Version: 1.0.0-demo</p>
    </div>

    <div class="projmodel-card" style="text-align: center; padding: 60px 20px;">
        <div class="projmodel-mvp-badge">
            $status
        </div>
        <p style="font-size: 18px; margin: 30px 0; color: #5e6c84;">
            $statusMessage
        </p>

        <!-- Сводная статистика (заглушка) -->
        <div class="deadline-stats">
            <div class="stat-card">
                <div class="stat-number">24</div>
                <div class="stat-label">Всего задач</div>
            </div>
            <div class="stat-card stat-critical">
                <div class="stat-number">3</div>
                <div class="stat-label">Критический риск</div>
            </div>
            <div class="stat-card stat-high">
                <div class="stat-number">5</div>
                <div class="stat-label">Высокий риск</div>
            </div>
            <div class="stat-card stat-medium">
                <div class="stat-number">7</div>
                <div class="stat-label">Средний риск</div>
            </div>
            <div class="stat-card stat-low">
                <div class="stat-number">9</div>
                <div class="stat-label">Низкий риск</div>
            </div>
        </div>

        <!-- Таблица задач с цветовой индикацией (заглушка) -->
        <div class="deadline-table-wrapper">
            <table class="deadline-table">
                <thead>
                    <tr>
                        <th>ID задачи</th>
                        <th>Название</th>
                        <th>Исполнитель</th>
                        <th>Дедлайн</th>
                        <th>Осталось</th>
                        <th>Выполнение</th>
                        <th>Риск</th>
                    </tr>
                </thead>
                <tbody>
                    <tr class="risk-critical">
                        <td>PROJ-142</td>
                        <td>Исправить критический баг</td>
                        <td>А</td>
                        <td>2026-04-10 18:00</td>
                        <td>0 дн. 2 ч.</td>
                        <td>30%</td>
                        <td><span class="risk-badge critical">Критический</span></td>
                    </tr>
                    <tr class="risk-high">
                        <td>PROJ-156</td>
                        <td>Реализовать REST API</td>
                        <td>Ар</td>
                        <td>2026-04-12 23:59</td>
                        <td>2 дн. 10 ч.</td>
                        <td>45%</td>
                        <td><span class="risk-badge high">Высокий</span></td>
                    </tr>
                    <tr class="risk-medium">
                        <td>PROJ-163</td>
                        <td>Написать документацию</td>
                        <td>И</td>
                        <td>2026-04-18 18:00</td>
                        <td>8 дн. 4 ч.</td>
                        <td>70%</td>
                        <td><span class="risk-badge medium">Средний</span></td>
                    </tr>
                    <tr class="risk-low">
                        <td>PROJ-171</td>
                        <td>Дизайн веб-панели</td>
                        <td>А</td>
                        <td>2026-04-25 12:00</td>
                        <td>15 дн. 0 ч.</td>
                        <td>85%</td>
                        <td><span class="risk-badge low">Низкий</span></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="projmodel-footer">
        ProjModel — умный помощник для Jira
    </div>
</div>
</body>
</html>