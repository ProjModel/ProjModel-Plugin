<atlassian-plugin key="${atlassian.plugin.key}" name="${project.name}" plugins-version="2">
    <plugin-info>
        <description>${project.description}</description>
        <version>${project.version}</version>
        <vendor name="${project.organization.name}" url="${project.organization.url}" />
        <param name="plugin-icon">images/pluginIcon.png</param>
        <param name="plugin-logo">images/pluginLogo.png</param>
    </plugin-info>

    <!-- add our i18n resource -->
    <resource type="i18n" name="i18n" location="projmodel"/>
    
    <!-- add our web resources -->
    <web-resource key="projmodel-resources" name="projmodel Web Resources">
        <dependency>com.atlassian.auiplugin:ajs</dependency>
        
        <resource type="download" name="projmodel.css" location="/css/projmodel.css"/>
        <resource type="download" name="projmodel.js" location="/js/projmodel.js"/>
        <resource type="download" name="images/" location="/images"/>

        <context>atl.general</context>
    </web-resource>

    <servlet name="hello-servlet"
             key="hello-servlet"
             class="com.projmodel.plugin.web.HelloServlet">
        <description>Hello Servlet</description>
        <url-pattern>/hello</url-pattern>
    </servlet>

    <servlet name="projmodel-home"
             key="projmodel-home"
             class="com.projmodel.plugin.web.HomeServlet">
        <description>ProjModel home page</description>
        <url-pattern>/projmodel</url-pattern>
    </servlet>

    <web-item key="projmodel-menu-item"
              name="ProjModel Menu Item"
              section="system.top.navigation.bar"
              weight="1000">
        <label key="projmodel.menu.label"/>
        <link linkId="projmodel-link">/plugins/servlet/projmodel</link>
    </web-item>

    <!-- Модуль Active Objects для работы с базой данных -->
    <ao key="ao-module">
        <description>База данных плагина ProjModel</description>
        <entity>com.projmodel.plugin.ao.ReminderLogAO</entity>
        <entity>com.projmodel.plugin.ao.ReportTaskAO</entity>
    </ao>

    <!-- Workload Servlet -->
    <servlet name="projmodel-workload"
             key="projmodel-workload"
             class="com.projmodel.plugin.web.WorkloadServlet">
        <description>ProjModel workload page</description>
        <url-pattern>/projmodel/workload</url-pattern>
    </servlet>

    <!-- Deadline Servlet -->
    <servlet name="projmodel-deadline"
             key="projmodel-deadline"
             class="com.projmodel.plugin.web.DeadlineServlet">
        <description>ProjModel deadline analysis page</description>
        <url-pattern>/projmodel/deadline</url-pattern>
    </servlet>

    <servlet name="debug-servlet"
             key="debug-servlet"
             class="com.projmodel.plugin.web.DebugServlet">
        <description>Debug Servlet</description>
        <url-pattern>/debug</url-pattern>
    </servlet>

    <servlet name="visibility-settings-servlet"
             key="visibility-settings-servlet"
             class="com.projmodel.plugin.web.VisibilitySettingsServlet">
        <description>ProjModel Visibility Settings</description>
        <url-pattern>/projmodel/visibility-settings</url-pattern>
    </servlet>

    <!-- Report Request Servlet -->
    <servlet name="projmodel-report-request"
             key="projmodel-report-request"
             class="com.projmodel.plugin.web.ReportRequestServlet">
        <description>Создание и скачивание отчётов ProjModel</description>
        <url-pattern>/projmodel/report-request</url-pattern>
    </servlet>

</atlassian-plugin>
